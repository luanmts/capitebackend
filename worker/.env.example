# ── Backend ───────────────────────────────────────────────────────────────────
# URL base do backend (sem trailing slash)
# Em produção: http://186.202.209.229/api
# Em desenvolvimento local: http://localhost:3001
API_BASE_URL=http://localhost:3001

# Chave secreta — deve corresponder a RODOVIA_WORKER_KEY no backend
RODOVIA_WORKER_KEY=troque-por-chave-segura

# ── Câmera ────────────────────────────────────────────────────────────────────
# URL RTSP do stream da câmera
# Exemplos:
#   rtsp://usuario:senha@192.168.1.10:554/stream
#   rtsp://192.168.1.10/live/ch0
RTSP_URL=

# ── Modelo YOLO ───────────────────────────────────────────────────────────────
# yolov8n.pt (rápido, CPU)  |  yolov8s.pt (mais preciso)  |  yolo11n.pt (latest)
# Na primeira execução o modelo é baixado automaticamente (~6MB para nano)
YOLO_MODEL=yolov8n.pt

# Confiança mínima para aceitar uma detecção (0.0–1.0)
CONFIDENCE_THRESHOLD=0.4

# Processa 1 a cada N frames (reduz carga CPU/GPU — 2 = ~15fps se stream 30fps)
FRAME_SKIP=2

# Dispositivo de inferência: cpu | cuda | mps (Apple Silicon)
DEVICE=cpu

# ── Classes de veículos ───────────────────────────────────────────────────────
# Nomes das classes COCO que devem ser contadas
VEHICLE_CLASSES=car,truck,bus,motorcycle

# ── Linha virtual ─────────────────────────────────────────────────────────────
# Coordenadas relativas (0.0–1.0) da linha de contagem no frame
# Linha horizontal no centro (padrão — boa para câmera acima da pista):
LINE_START=0.0,0.5
LINE_END=1.0,0.5
#
# Linha vertical no centro (câmera lateral):
# LINE_START=0.5,0.0
# LINE_END=0.5,1.0

# ── Timing ────────────────────────────────────────────────────────────────────
METRICS_INTERVAL_SEC=10
POLL_INTERVAL_SEC=5
FINALIZE_BEFORE_SEC=20

# ── Log ───────────────────────────────────────────────────────────────────────
# DEBUG mostra cada cruzamento detectado
LOG_LEVEL=INFO
