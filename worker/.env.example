# URL base do backend (sem trailing slash)
# Em produção: http://186.202.209.229/api
# Em desenvolvimento local: http://localhost:3001
API_BASE_URL=http://localhost:3001

# Chave secreta do worker — deve corresponder a RODOVIA_WORKER_KEY no backend
RODOVIA_WORKER_KEY=troque-por-chave-segura

# Intervalo de envio de métricas parciais (segundos)
METRICS_INTERVAL_SEC=10

# Intervalo de polling ao aguardar novo round (segundos)
POLL_INTERVAL_SEC=5

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
